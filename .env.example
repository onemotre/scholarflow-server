HTTP_ADDR=:8080
DATABASE_URL=postgres://scholarflow:scholarflow@postgres:5432/scholarflow?sslmode=disable
REDIS_ADDR=redis:6379
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=scholarflow
MINIO_SECRET_KEY=scholarflow-secret
MINIO_BUCKET=scholarflow
MINIO_USE_SSL=false
GROBID_URL=http://grobid:8070
MAX_UPLOAD_BYTES=52428800

# LLM reader (leave blank to disable; jobs stop at "parsed")
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_INPUT_CHARS=48000
OPENAI_TIMEOUT_SECONDS=120
OPENAI_API_STYLE=chat
OPENAI_RESPONSE_FORMAT=json_schema
OPENAI_SYSTEM_PROMPT_PATH=/app/prompts/system_zh.md
READ_MAX_RETRY=3
JOB_FAILED_RETENTION_DAYS=7
JOB_CLEANUP_CRON=@daily
